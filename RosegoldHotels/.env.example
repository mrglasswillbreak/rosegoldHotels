# ==============================================
# RosegoldHotels Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# =========================
# CORE SETTINGS (Required)
# =========================

# Django secret key - MUST be unique and secret in production
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug mode - MUST be false in production
DEBUG=true

# Allowed hosts - comma-separated list
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins - comma-separated full URLs (include https://)
# CSRF_TRUSTED_ORIGINS=https://your-domain.com

# =========================
# DATABASE (Optional)
# =========================
# Uses SQLite by default. Set DATABASE_URL for PostgreSQL/MySQL
# DATABASE_URL=postgres://user:password@host:5432/dbname

# =========================
# CACHING (Optional)
# =========================
# Set REDIS_URL for production caching
# REDIS_URL=redis://localhost:6379/1

# =========================
# PAYMENT GATEWAY (Paystack)
# =========================
# Get keys from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxx
PAYSTACK_CURRENCY=NGN

# =========================
# RECEPTIONIST ACCOUNT
# =========================
# Default receptionist account created on first run
DEFAULT_RECEPTIONIST_EMAIL=receptionist@yourhotel.com
DEFAULT_RECEPTIONIST_PASSWORD=ChangeThisSecurePassword123!
DEFAULT_RECEPTIONIST_FIRST_NAME=Front
DEFAULT_RECEPTIONIST_LAST_NAME=Desk
DEFAULT_RECEPTIONIST_PHONE=
DEFAULT_RECEPTIONIST_THEME=light
DEFAULT_RECEPTIONIST_IS_ACTIVE=true
DEFAULT_RECEPTIONIST_SYNC_PASSWORD=false

# =========================
# EMAIL (Optional)
# =========================
# Leave unset in development to show activation links on-screen
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=noreply@rosegoldhotels.com
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@provider.com
# EMAIL_HOST_PASSWORD=your-email-password
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false

# =========================
# IOT ALERTS (Optional)
# =========================
# IOT_MONITOR_AUTOSTART=true
# IOT_MONITOR_INTERVAL_SECONDS=30
# IOT_ALERT_EMAIL_ENABLED=true
# IOT_ALERT_SMS_ENABLED=false

# =========================
# TWILIO SMS (Optional)
# =========================
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890
