# Real email delivery
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=alerts@yourhotel.com
SERVER_EMAIL=alerts@yourhotel.com
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=alerts@yourhotel.com
EMAIL_HOST_PASSWORD=replace-with-email-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# Real SMS delivery
IOT_ALERT_SMS_BACKEND=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Optional additional recipients
IOT_ALERT_EXTRA_EMAIL_RECIPIENTS=
IOT_ALERT_EXTRA_SMS_RECIPIENTS=

# Monitoring behavior
IOT_MONITOR_AUTOSTART=true
IOT_MONITOR_INTERVAL_SECONDS=30
IOT_ALERT_REMINDER_MINUTES=10
IOT_ALERT_EMAIL_ENABLED=true
IOT_ALERT_SMS_ENABLED=true
IOT_SIM_ABNORMAL_ROOM_RATE=0.20
